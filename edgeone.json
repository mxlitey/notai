{
  "name": "notai",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "cloudFunctions": {
    "nodejs": {
      "maxDuration": 120
    }
  },
  "env": {
    "API_BASE_URL": "@api_base_url",
    "API_KEY": "@api_key",
    "PROMPT_MODEL": "@prompt_model",
    "AUTH_SECRET": "@auth_secret",
    "JWT_SECRET": "@jwt_secret",
    "PUBLIC_API_KEY": "@public_api_key"
  }
}
